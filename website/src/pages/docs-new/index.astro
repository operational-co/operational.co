---
// @ts-nocheck
import BaseLayout from "@/layouts/base.astro";
import { list, getItems } from "@/content/list.js";
import Prevnext from "@operational.co/components/ui/prevnext.vue";
import PageApi from "@/components/page-api.vue";
import { getEntry, render } from "astro:content";

const baseSlug = "docsnew";

const post = await getEntry(baseSlug, "introduction");
const { Content } = await render(post);

const { prevListItem, nextListItem } = getItems(list, "docs-new/introduction");
---

<BaseLayout>
  <PageApi client:load pathname={Astro.url.pathname}>
    <div class="c-page">
      <Content />
      <Prevnext prev={prevListItem} next={nextListItem} />
    </div>
  </PageApi>
</BaseLayout>
