---
import BaseLayout from "@/layouts/base.astro";
import { list } from "@/content/list.js";
import { buildApiPrevNext, buildApiTocList } from "@/lib/api-docs.js";
import Prevnext from "@operational.co/components/ui/prevnext.vue";
import PageApi from "@/components/page-api.vue";
import { getCollection, render } from "astro:content";

const apiEntries = await getCollection("api");

const currentSlug = Astro.params.slug;
let post = null;

for (let i = 0; i < apiEntries.length; i++) {
  const entry = apiEntries[i];
  if (entry && entry.data && entry.data.slug === currentSlug) {
    post = entry;
    break;
  }
}

if (!post) {
  return;
}

const { Content } = await render(post);
const pageTitle = post.data.title;
const tocItems = buildApiTocList(list, apiEntries);
const nav = buildApiPrevNext(apiEntries, currentSlug);

export async function getStaticPaths() {
  const entries = await getCollection("api");
  const paths = [];

  for (let i = 0; i < entries.length; i++) {
    const entry = entries[i];
    if (!entry || !entry.data || !entry.data.slug) {
      continue;
    }

    paths.push({
      params: {
        slug: entry.data.slug,
      },
    });
  }

  return paths;
}
---

<BaseLayout>
  <PageApi client:load pathname={Astro.url.pathname} title={pageTitle} tocItems={tocItems}>
    <div class="c-page">
      <Content />
      <Prevnext prev={nav.prev} next={nav.next} />
    </div>
  </PageApi>
</BaseLayout>
